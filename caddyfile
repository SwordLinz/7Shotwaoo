# Production HTTPS reverse proxy for Wacoo.
#
# Usage:
# 1. Point your domain DNS A record to this server.
# 2. Export WACOO_DOMAIN before starting Caddy.
#    Example: export WACOO_DOMAIN=wacoo.company.com
# 3. Run: caddy run --config Caddyfile

{$WACOO_DOMAIN} {
    handle_path /admin/queues* {
        reverse_proxy localhost:13010
    }

    handle {
        reverse_proxy localhost:13000
    }
}
