# ============================================================
# Railway 部署环境变量模板
# 用法：在 Railway service Variables 的 Raw Editor 粘贴对应段落
# 详见：docs/03-railway-deployment.md
# ============================================================

# ==================== web + worker 共享段 ====================

# 数据库（Railway MySQL plugin 变量引用）
DATABASE_URL=${{MySQL.MYSQL_URL}}

# Redis (Upstash Free Plan)
REDIS_HOST=<your-upstash-host>.upstash.io
REDIS_PORT=6379
REDIS_USERNAME=default
REDIS_PASSWORD=<upstash-password>
REDIS_TLS=true

# 存储 (Cloudflare R2)
STORAGE_TYPE=minio
MINIO_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
MINIO_REGION=auto
MINIO_BUCKET=waoowaoo
MINIO_ACCESS_KEY=<r2-access-key-id>
MINIO_SECRET_KEY=<r2-secret-access-key>
MINIO_FORCE_PATH_STYLE=true

# 认证
NEXTAUTH_URL=https://waoo.nakocai.com
NEXTAUTH_SECRET=<openssl rand -base64 32>
WACOO_DOMAIN=waoo.nakocai.com

# 内部密钥（生产请独立生成；不可与 docker-compose.yml 默认值相同）
CRON_SECRET=<openssl rand -hex 32>
INTERNAL_TASK_TOKEN=<openssl rand -hex 32>
API_ENCRYPTION_KEY=<openssl rand -hex 32>

# Worker 配置（web service 也需读取，部分代码共享）
WATCHDOG_INTERVAL_MS=30000
TASK_HEARTBEAT_TIMEOUT_MS=90000
QUEUE_CONCURRENCY_IMAGE=20
QUEUE_CONCURRENCY_VIDEO=10
QUEUE_CONCURRENCY_VOICE=10
QUEUE_CONCURRENCY_TEXT=20

# 日志
LOG_UNIFIED_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_DEBUG_ENABLED=false
LOG_AUDIT_ENABLED=true
LOG_SERVICE=wacoo
LOG_REDACT_KEYS=password,token,apiKey,apikey,authorization,cookie,secret,access_token,refresh_token

# 计费 / 流式
BILLING_MODE=OFF
LLM_STREAM_EPHEMERAL_ENABLED=true

# ==================== 仅 worker service 追加 ====================

# Bull Board（队列管理面板，走 Cloudflare Tunnel queues.<domain>）
BULL_BOARD_HOST=0.0.0.0
BULL_BOARD_PORT=3010
BULL_BOARD_BASE_PATH=/admin/queues
BULL_BOARD_USER=admin
BULL_BOARD_PASSWORD=<openssl rand -base64 24>

# ==================== 仅 cloudflared service ====================

# Cloudflare Zero Trust 创建 Tunnel 时获取
TUNNEL_TOKEN=<eyJh...long-token>
